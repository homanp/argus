PORT=8787
RELAY_DB_PATH=./data/relay.db
GITHUB_WEBHOOK_SECRET=replace-me

# A Cloudflare tunnel starts automatically so webhook URLs are publicly
# reachable. Set RELAY_BASE_URL to a public HTTPS address to skip the
# tunnel and use your own domain instead.
# RELAY_BASE_URL=https://relay.your-domain.com

# Set to 1 on a fresh install to seed four demo missions so the Missions view
# has something to show before any real webhooks have arrived. Noops if any
# mission already exists.
# MISSION_SEED_DEMO=1
